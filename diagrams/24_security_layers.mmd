graph TB
    subgraph "Security Architecture - All Layers"
        subgraph "Layer 1: Client"
            OAUTH[OAuth 2.0 + MFA]
            SESSION[JWT Sessions<br/>15-min expiry]
        end

        subgraph "Layer 2: Network"
            WAF[WAF<br/>OWASP Top 10]
            DDOS[DDoS Protection]
            TLS[TLS 1.3 Only]
            FW[Zone Firewalls]
        end

        subgraph "Layer 3: Application"
            VALID[Input Validation]
            RBAC[RBAC/ABAC]
            RATE[Rate Limiting]
        end

        subgraph "Layer 4: Agent Core"
            TOOLS[Tool Allowlist]
            INJECT[Prompt Injection<br/>Defense]
            AUDIT[Pre-Execution<br/>Audit Logging]
        end

        subgraph "Layer 5: AI Layer"
            ISOLATE[Network Isolation<br/>No Internet]
            GUARD[Output Guardrails]
            VERIFY[Model Checksum<br/>Verification]
        end

        subgraph "Layer 6: Data"
            ENCRYPT[AES-256 Encryption]
            HSM[HSM Key Management]
            RLS[Row-Level Security]
            MASK[Data Masking]
        end

        subgraph "Layer 7: Integration"
            MTLS[mTLS Authentication]
            SIGN[Message Signing]
            ALLOW[Agent Allowlist]
        end
    end

    OAUTH --> WAF
    WAF --> VALID
    VALID --> TOOLS
    TOOLS --> ISOLATE
    ISOLATE --> ENCRYPT
    ENCRYPT --> MTLS

