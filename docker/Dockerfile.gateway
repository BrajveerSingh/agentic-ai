# syntax=docker/dockerfile:1

FROM maven:3.9-eclipse-temurin-25 AS build
WORKDIR /workspace
COPY . .
RUN mvn -q -DskipTests package -pl ata-gateway-app -am

FROM eclipse-temurin:25-jre
WORKDIR /app
COPY --from=build /workspace/ata-gateway-app/target/ata-gateway-app-*.jar /app/app.jar
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "/app/app.jar"]

