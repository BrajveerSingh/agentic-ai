# syntax=docker/dockerfile:1

FROM maven:3.9-eclipse-temurin-25 AS build
WORKDIR /workspace

# Copy the whole multi-module project so we can build with -pl/-am
COPY . .

RUN mvn -q -DskipTests package -pl ata-mock-credit-bureau-app -am

FROM eclipse-temurin:25-jre
WORKDIR /app

COPY --from=build /workspace/ata-mock-credit-bureau-app/target/ata-mock-credit-bureau-app-*.jar /app/app.jar

EXPOSE 8080

ENTRYPOINT ["java", "-jar", "/app/app.jar"]

